# maven environment variables for docker-compose
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: AI provider API key
MAVEN_API_KEY=sk-ant-...

# Optional: Telegram bot token
MAVEN_TELEGRAM_TOKEN=

# Optional: Feishu bot credentials
MAVEN_FEISHU_APP_ID=
MAVEN_FEISHU_APP_SECRET=

# Optional: WeCom intelligent bot credentials
MAVEN_WECOM_TOKEN=
MAVEN_WECOM_ENCODING_AES_KEY=
MAVEN_WECOM_RECEIVE_ID=

# Optional: platform speech (STT/TTS for Web voice, future channel voice ingress)
MAVEN_DEEPGRAM_API_KEY=
MAVEN_ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Cartesia TTS (speech.ttsProvider cartesia) — https://docs.cartesia.ai/get-started/make-an-api-request
MAVEN_CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
# Optional: defaults sonic-2; Cartesia-Version header defaults to 2025-04-16
CARTESIA_MODEL_ID=
CARTESIA_API_VERSION=
