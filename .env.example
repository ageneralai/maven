# maven environment variables for docker-compose
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: AI provider API key
MAVEN_API_KEY=sk-ant-...

# Optional: Telegram bot token
MAVEN_TELEGRAM_TOKEN=

# Optional: Feishu bot credentials
MAVEN_FEISHU_APP_ID=
MAVEN_FEISHU_APP_SECRET=

# Optional: WeCom intelligent bot credentials
MAVEN_WECOM_TOKEN=
MAVEN_WECOM_ENCODING_AES_KEY=
MAVEN_WECOM_RECEIVE_ID=
